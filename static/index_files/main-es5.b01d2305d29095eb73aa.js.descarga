a - Los 12 deseos",1,"video-container"],[1,"aventurista-grid"],["target","_blank","rel","noopener","class","aventurista-card",3,"href",4,"ngFor","ngForOf"],[1,"news-grid"],["target","_blank","rel","noopener",1,"aventurista-card",3,"href"],[1,"aventurista-card-thumb"],["loading","lazy",1,"aventurista-card-thumb-img",3,"src","alt"],[1,"aventurista-card-chapter"],[1,"aventurista-card-duration"],[1,"aventurista-card-info"],[1,"aventurista-card-title"],[1,"aventurista-card-meta"],["loading","lazy",1,"news-card-thumb-img",3,"src","alt"]],template:function(e,t){1&e&&(s.Yb(0,"main",0),s.Yb(1,"div",1),s.Tb(2,"app-principal-slider",2),s.Xb(),s.Yb(3,"section",3),s.Yb(4,"div",4),s.Yb(5,"h1",5),s.Yc(6,"Alexis Ortega Adie"),s.Xb(),s.Yb(7,"h4",6),s.Yc(8,"Un talentoso artista con una sorprendente creatividad que dej\xf3 huella en todos quienes tuvimos la suerte de conocerlo."),s.Xb(),s.Yb(9,"p",7),s.Yc(10,"El legado de Alexis Ortega"),s.Xb(),s.Yb(11,"p",8),s.Yc(12," Mundo Joven, lamenta profundamente la partida de nuestro Director Creativo, Alexis Ortega, un ser excepcional que no solo lider\xf3 nuestra visi\xf3n creativa con sus innovadoras ideas, sino que fue parte esencial en la construcci\xf3n de la imagen y la personalidad de nuestras marcas. Alexis Ortega fue un polifac\xe9tico actor, locutor, actor de doblaje y creativo mexicano que toc\xf3 miles de corazones con su talento y sensibilidad. Desde sus primeros trabajos en Mundo Joven, particip\xf3 en el proyecto. El Aventurista y form\xf3 parte de la "),s.Yb(13,"a",9),s.Yc(14," campa\xf1a televisiva grabada en Nueva York junto a Luis Gerardo M\xe9ndez"),s.Xb(),s.Yc(15,". Realiz\xf3 m\xfaltiples grabaciones y fue imagen de Mundo Joven Fest en redes sociales. Su huella creativa qued\xf3 marcada especialmente en la construcci\xf3n de nombres e identidad visual de marcas hermanas como Book&Learn, El Salvaje y S\xed Te Vas, as\xed como en campa\xf1as como Solo Viaja para este 2026. Adem\xe1s, contribuy\xf3 activamente en la gesti\xf3n de redes sociales, aportando siempre una visi\xf3n fresca, aut\xe9ntica y profundamente humana. "),s.Tb(16,"br"),s.Tb(17,"br"),s.Yc(18," Sumado a lo anterior, fue un reconocido artista por su trabajo en doblaje y televisi\xf3n; dio voz en espa\xf1ol latino a Spider-Man (interpretado por Tom Holland) en pel\xedculas del Universo Cinematogr\xe1fico de Marvel como Capit\xe1n Am\xe9rica: Civil War, Spider-Man: Homecoming y Avengers: Infinity War. M\xe1s all\xe1 de los reflectores, fue un apasionado de los viajes y de la comunicaci\xf3n visual, una mente inquieta que encontraba belleza en el movimiento y en las historias compartidas. Conectaba con las audiencias desde la autenticidad y la empat\xeda. Se form\xf3 en la actuaci\xf3n tanto para doblaje como para imagen real, lo que le permiti\xf3 navegar con \xe9xito entre los micr\xf3fonos de las cabinas de grabaci\xf3n y los sets de filmaci\xf3n de importantes plataformas de streaming. "),s.Tb(19,"br"),s.Tb(20,"br"),s.Yc(21," Alexis nos dej\xf2 el 26 de enero de 2026, a los 36 a\xf1os de edad, una noticia que llen\xf3 de tristeza a la industria del entretenimiento y dejar\xe0 un profundo vac\xedo permanente no solo entre sus familiares, sino entre amigos, colaboradores y seguidores, quienes hoy lamentan su partida, dejando como \xfaltimo legado un mar de sonrisas, buenos momentos y muchas ense\xf1anzas que guardaremos toda la vida y que esperamos hayan contribuido a enriquecer las experiencias de la comunidad viajera. "),s.Xb(),s.Yb(22,"p",7),s.Yc(23,"Aportaciones en Cine y TV:"),s.Xb(),s.Yb(24,"div",10),s.Yb(25,"p",11),s.Yc(26,"Adem\xe1s de ser la voz de Peter Parker, su carrera abarc\xf3 diversos \xe1mbitos de la actuaci\xf3n:"),s.Xb(),s.Yb(27,"ul",12),s.Yb(28,"li"),s.Yb(29,"b"),s.Yc(30,"Doblaje de Cine y Animaci\xf3n"),s.Xb(),s.Yc(31,": Interpret\xf3 a Tadashi Hamada en Big Hero 6, a Tobio Kageyama en el anime Haikyuu!! y particip\xf3 en producciones como Buscando a Dory, Cars 3 y Rogue One: Una historia de Star Wars."),s.Xb(),s.Yb(32,"li"),s.Yb(33,"b"),s.Yc(34,"Televisi\xf3n"),s.Xb(),s.Yc(35,': Actu\xf3 frente a las c\xe1maras en series populares, destacando sus papeles como Jorge "El Burro" Van Rankin en Luis Miguel: la serie y como Federico "DJ Freddy" Limantour en La Casa de las Flores.'),s.Xb(),s.Yb(36,"li"),s.Yb(37,"b"),s.Yc(38,"Otras colaboraciones"),s.Xb(),s.Yc(39,": Fue la voz recurrente para el canal en espa\xf1ol del creador de contenido MrBeast."),s.Xb(),s.Xb(),s.Yb(40,"p",13),s.Yc(41,"Su cat\xe1logo de personajes es extenso y abarca desde blockbusters de Hollywood hasta anime japon\xe9s"),s.Xb(),s.Xb(),s.Yb(42,"p",7),s.Yc(43,"Cine y Animaci\xf3n (Doblaje)"),s.Xb(),s.Yb(44,"div",10),s.Yb(45,"ul",12),s.Yb(46,"li"),s.Yc(47,"Spider-Man (Peter Parker): Fue la voz oficial en espa\xf1ol latino para el Universo Cinematogr\xe1fico de Marvel, interpretando a Tom Holland en hitos como Capit\xe1n Am\xe9rica: Civil War, Spider-Man: Homecoming y Avengers: Infinity War."),s.Xb(),s.Yb(48,"li"),s.Yc(49,"Tadashi Hamada: Dio vida al entra\xf1able hermano mayor en la pel\xedcula de Disney, Grandes H\xe9roes (Big Hero 6)."),s.Xb(),s.Yb(50,"li"),s.Yc(51,"Tobio Kageyama: Una interpretaci\xf3n ic\xf3nica para la comunidad del anime en la serie deportiva Haikyuu!!."),s.Xb(),s.Yb(52,"li"),s.Yc(53,"Cassian Andor (voz joven): Su incursi\xf3n en el universo de Star Wars, aportando profundidad al origen de este legendario personaje."),s.Xb(),s.Yb(54,"li"),s.Yc(55,"Colaboraciones de \xc9lite: Prest\xf3 su talento para voces adicionales y personajes clave en grandes producciones como Cars 3, Buscando a Dory, Rogue One: Una historia de Star Wars y la serie CSI."),s.Xb(),s.Yb(56,"li"),s.Yc(57,"Fen\xf3meno Digital: Fue la voz institucional de la versi\xf3n redoblada de MrBeast, conectando con millones de seguidores en todo el mundo hispano."),s.Xb(),s.Xb(),s.Xb(),s.Yb(58,"p",14),s.Yc(59,"Series de Televisi\xf3n"),s.Xb(),s.Yb(60,"div",10),s.Yb(61,"ul",12),s.Yb(62,"li"),s.Yc(63,"Luis Miguel: la serie: Interpret\xf3 a Luis Miguel, el cantante m\xe1s popular de M\xe9xico, en la serie de televisi\xf3n de Netflix."),s.Xb(),s.Yb(64,"li"),s.Yc(65,'La Casa de las Flores: Interpret\xf3 a Federico "DJ Freddy" Limantour, un personaje que se encargaba de la m\xfasica en la serie de televisi\xf3n de Netflix.'),s.Xb(),s.Xb(),s.Xb(),s.Yb(66,"p",14),s.Yc(67,"Locuci\xf3n Comercial y Anuncios"),s.Xb(),s.Yb(68,"div",10),s.Yb(69,"p",11),s.Yc(70,"Alexis fue una voz recurrente para marcas de prestigio. Su tono juvenil y confiable lo llev\xf3 a ser locutor institucional en campa\xf1as de:"),s.Xb(),s.Yb(71,"ul",12),s.Yb(72,"li"),s.Yc(73,"Innovaci\xf3n en el Turismo: Como Director Creativo de Mundo Joven, transform\xf3 la comunicaci\xf3n de la empresa, inyectando un esp\xedritu joven, din\xe1mico y aspiracional que moderniz\xf3 la identidad de la marca."),s.Xb(),s.Yb(74,"li"),s.Yc(75,"Participaci\xf3n en series viajeras como El Aventurista."),s.Xb(),s.Yb(76,"li"),s.Yc(77,"Puente cultural: Uni\xf3 el mundo del entretenimiento con el del turismo, utilizando su talento vocal y actoral para profesionalizar la narrativa de los viajes en M\xe9xico."),s.Xb(),s.Yb(78,"li"),s.Yc(79,"Sector Automotriz: Anuncios para marcas como Ford."),s.Xb(),s.Yb(80,"li"),s.Yc(81,'Consumo masivo: Campa\xf1as para refrescos y comida r\xe1pida donde se buscaba un perfil "millennial" o cercano.'),s.Xb(),s.Xb(),s.Yb(82,"p",13),s.Yc(83,"Sin embargo, m\xe1s all\xe1 de los reflectores y las cabinas de grabaci\xf3n, Alexis fue un apasionado incansable de los viajes y la comunicaci\xf3n visual. Como una mente inquieta que encontraba belleza en el movimiento y en las historias compartidas, lograba conectar con las audiencias desde una autenticidad y empat\xeda que pocos poseen. Para nosotros, no solo fue la voz institucional que invitaba a descubrir el mundo; fue el esp\xedritu aventurero que nos record\xf3 que viajar es, ante todo, una forma de conectar con nuestra propia humanidad."),s.Xb(),s.Xb(),s.Yb(84,"div",15),s.Yb(85,"div",16),s.Yb(86,"p",7),s.Yc(87,"Su Legado Final: Los 12 Deseos de 2026"),s.Xb(),s.Yb(88,"p",8),s.Yc(89,' Su \xfaltima gran actuaci\xf3n fue para s\xed mismo y para su comunidad. En la campa\xf1a de "Los 12 deseos para todos los viajeros", Alexis utiliz\xf3 su voz institucional de Mundo Joven pero con la intenci\xf3n actoral de una despedida o un legado. En este trabajo, cada palabra fue cargada con la autenticidad de quien realmente ha recorrido el mundo, cerrando su carrera no con un gui\xf3n ajeno, sino con sus propias convicciones. '),s.Xb(),s.Xb(),s.Tb(90,"video",17),s.Xb(),s.Yb(91,"p",14),s.Yc(92,"Serie El Aventurista con Alexis, Tato y Morfo."),s.Xb(),s.Yb(93,"div",18),s.Wc(94,ZN,12,8,"a",19),s.Xb(),s.Yb(95,"p",14),s.Yc(96,"Homenaje en medios: part\xedcipes del legado que Alexis Ortega dej\xf3"),s.Xb(),s.Yb(97,"div",20),s.Wc(98,JN,2,3,"a",19),s.Xb(),s.Xb(),s.Xb(),s.Xb()),2&e&&(s.Db(2),s.wc("route",t.route)("load_serv",!1)("data",t.dataServ.banners)("video",null==t.dataServ.general?null:t.dataServ.general.video),s.Db(92),s.wc("ngForOf",t.aventuristaChapters),s.Db(4),s.wc("ngForOf",t.newsGoogleArticles))},directives:[Qd,u.t],styles:['.alexis-ortega-landing[_ngcontent-%COMP%]{min-height:100vh}.header-widget-banner.alexis-ortega-hero[_ngcontent-%COMP%]{margin-bottom:0}.alexis-ortega-intro[_ngcontent-%COMP%]{padding:0;text-align:center}.alexis-ortega-intro[_ngcontent-%COMP%]   .landing-title[_ngcontent-%COMP%]{font-family:Inter,sans-serif;font-weight:700;font-size:2.5rem;line-height:1.2;color:#00091e;margin-bottom:1rem;text-align:left;margin-top:0;padding-top:0}.alexis-ortega-intro[_ngcontent-%COMP%]   .landing-subtitle[_ngcontent-%COMP%]{font-size:2rem}.alexis-ortega-intro[_ngcontent-%COMP%]   .header-paragraph[_ngcontent-%COMP%], .alexis-ortega-intro[_ngcontent-%COMP%]   .landing-subtitle[_ngcontent-%COMP%]{font-family:Inter,sans-serif;font-weight:600;color:#00091e;margin-bottom:1rem;text-align:left}.alexis-ortega-intro[_ngcontent-%COMP%]   .header-parag